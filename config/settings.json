{
  "name": "YOUTUBEDROP",
  "version": "0.1.0",
  "youtube_api_key": "${YOUTUBE_API_KEY}",
  "download_dir": "downloads",
  "output_dir": "output",
  "max_video_duration": 3600,
  "supported_formats": ["mp4", "webm", "mp3"],
  "ncl_integration": true,
  "default_privacy": "private",
  "default_category_id": "22",
  "script_defaults": {
    "duration_min": 10,
    "tone": "educational, energetic"
  }
}
