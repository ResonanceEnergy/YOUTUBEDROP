# ========================================
# YOUTUBEDROP — OpenClaw Agent Config
# ========================================
# Copy this file to .env and fill in your values

# --- YouTube ---
YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_V3_KEY
# Comma-separated channel IDs or a file path (channels.txt)
YOUTUBE_CHANNEL_IDS=UCX6OQ3DkcsbYNE6H8uQQuVA,UC-9-kyTW8ZkZNDHQJ6FgpwQ

# --- Telegram Bot ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Discord Bot ---
# Get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# --- Paths ---
DATA_ROOT=./data                # where raw/derived artifacts go
NCL_ROOT=./ncl_out              # where briefs/packets land for NCL
TEMP_ROOT=./.tmp
DOWNLOAD_DIR=./downloads
DATABASE_URL=sqlite:///./youtubedrop.db

# --- NCC / GitHub Routing (optional) ---
GITHUB_TOKEN=ghp_XXXX
# Mapping org→repo (owner/repo). Use comma-separated or JSON.
NCC_REPO_MAP_JSON={"AAC":"ResonanceEnergy/AAC","NCL":"ResonanceEnergy/NCL","FuturePredictor":"ResonanceEnergy/future-predictor-council"}

# --- Behavior ---
MAX_NEWS_CLIP_SECONDS=60
MAX_INSIGHT_CLIP_SECONDS=300
DAILY_TOP_K=10
TIMEZONE=America/Vancouver

# --- OpenClaw Agent Settings ---
MAX_CONCURRENT_DOWNLOADS=3
AUDIO_ONLY=true
DOWNLOAD_TRANSCRIPT=true
DOWNLOAD_THUMBNAIL=true
MAX_DURATION=0

# --- Logging ---
LOG_LEVEL=INFO
